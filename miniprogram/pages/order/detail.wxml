<!--pages/order/detail.wxml-->
<view class="container">
  <!-- 订单状态 -->
  <view class="order-status" wx:if="{{orderDetail.status === 1}}">
    <text class="status-icon">⏳</text>
    <text class="status-text">{{orderDetail.statusText}}</text>
    <text class="status-desc">请尽快完成支付</text>
  </view>
  
  <!-- 订单基本信息 -->
  <view class="order-info">
    <view class="info-item">
      <text class="info-label">订单号：</text>
      <text class="info-value">{{orderDetail.orderNo}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">创建时间：</text>
      <text class="info-value">{{orderDetail.addtime}}</text>
    </view>
  </view>
  
  <!-- 服装信息 -->
  <view class="fuzhuang-info">
    <view class="section-title">服装信息</view>
    <view class="fuzhuang-item">
      <image src="{{orderDetail.fuzhuangImage}}" mode="aspectFill" class="fuzhuang-image"></image>
      <view class="fuzhuang-details">
        <text class="fuzhuang-name">{{orderDetail.fuzhuangmingcheng}}</text>
        <text class="fuzhuang-type">{{orderDetail.zujietypeText}}</text>
      </view>
    </view>
  </view>
  
  <!-- 租借信息 -->
  <view class="rent-info">
    <view class="section-title">租借信息</view>
    <view class="info-item">
      <text class="info-label">租借类型：</text>
      <text class="info-value">{{orderDetail.zujietypeText}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">租借天数：</text>
      <text class="info-value">{{orderDetail.rentDays}} 天</text>
    </view>
    <view class="info-item">
      <text class="info-label">租借数量：</text>
      <text class="info-value">{{orderDetail.quantity}} 件</text>
    </view>
  </view>
  
  <!-- 费用明细 -->
  <view class="cost-info">
    <view class="section-title">费用明细</view>
    <view class="info-item">
      <text class="info-label">服装单价：</text>
      <text class="info-value">¥{{orderDetail.jiage}}/{{orderDetail.zujietype === '1' ? '天' : '月'}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">租借费用：</text>
      <text class="info-value">¥{{orderDetail.totalPrice}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">保证金：</text>
      <text class="info-value">¥{{orderDetail.baozhengjin}}</text>
    </view>
    <view class="info-item total">
      <text class="info-label">总计：</text>
      <text class="info-value total-price">¥{{orderDetail.totalPrice + orderDetail.baozhengjin}}</text>
    </view>
  </view>
  
  <!-- 收货信息 -->
  <view class="contact-info">
    <view class="section-title">收货信息</view>
    <view class="info-item">
      <text class="info-label">联系人：</text>
      <text class="info-value">{{orderDetail.contactName}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">联系电话：</text>
      <text class="info-value">{{orderDetail.contactPhone}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">联系地址：</text>
      <text class="info-value">{{orderDetail.contactAddress}}</text>
    </view>
  </view>
  
  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{orderDetail.status === 1}}">
    <view class="cancel-btn" bindtap="cancelOrder">
      <text class="cancel-text">取消订单</text>
    </view>
    <view class="pay-btn" bindtap="goPay">
      <text class="pay-text">立即支付</text>
    </view>
  </view>
</view>
