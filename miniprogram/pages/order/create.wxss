.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 购物车商品列表 */
.cart-items {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.cart-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-item:last-child {
  border-bottom: none;
}

.cart-item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  object-fit: cover;
}

.cart-item-details {
  flex: 1;
}

.cart-item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.cart-item-size {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.cart-item-option {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
}

.cart-item-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.cart-item-quantity {
  font-size: 24rpx;
  color: #666;
  display: block;
}

/* 服装信息 */
.fuzhuang-info {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.fuzhuang-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
  object-fit: cover;
}

.fuzhuang-details {
  flex: 1;
}

.fuzhuang-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.fuzhuang-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}

.fuzhuang-category {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.fuzhuang-size {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
}

/* 订单信息 */
.order-info {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* 订单详情 */
.order-details {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.order-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-label {
  font-size: 28rpx;
  color: #666;
}

.order-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 时间选择器 */
.time-picker {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.time-item {
  display: flex;
  align-items: center;
}

.time-label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.picker {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 15rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
}

/* 数量选择器 */
.quantity-picker {
  display: flex;
  align-items: center;
  width: 200rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.quantity-input {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

/* 联系人信息 */
.contact-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.contact-item {
  display: flex;
  align-items: center;
}

.contact-label {
  font-size: 28rpx;
  color: #666;
  width: 120rpx;
}

.contact-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  padding: 15rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
}

/* 订单金额 */
.order-amount {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 100rpx;
}

.amount-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 15rpx;
}

.amount-label {
  font-size: 28rpx;
  color: #666;
}

.amount-value {
  font-size: 28rpx;
  color: #333;
}

.amount-item.total {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

/* 底部提交按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.total-amount {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.total-amount-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.submit-btn {
  background-color: #1677FF;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  margin-left: 20rpx;
}

.submit-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
