.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 订单状态筛选 */
.order-status-filter {
  margin-bottom: 20rpx;
  background-color: #fff;
  padding: 10rpx 0;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.status-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.status-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  margin-right: 20rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f5f5f5;
}

.status-item.active {
  background-color: #1677FF;
  color: #fff;
}

/* 订单列表 */
.order-list {
  margin-bottom: 20rpx;
}

.order-item {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-id {
  font-size: 28rpx;
  color: #333;
}

.order-status {
  font-size: 28rpx;
  color: #1677FF;
  font-weight: bold;
}

.order-content {
  display: flex;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  object-fit: cover;
}

.order-info {
  flex: 1;
}

.order-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.order-type {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  background-color: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  display: inline-block;
}

.order-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-actions {
  display: flex;
  gap: 10rpx;
}

.action-button {
  padding: 10rpx 30rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 1rpx solid #1677FF;
  background-color: #fff;
  color: #1677FF;
}

.action-button.pay-button {
  background-color: #1677FF;
  color: #fff;
}

.action-button.view-button {
  border: 1rpx solid #999;
  color: #666;
}

/* 空状态 */
.no-data {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}