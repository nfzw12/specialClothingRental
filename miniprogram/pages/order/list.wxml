<!--pages/order/list.wxml-->
<view class="container">
  <!-- 订单状态筛选 -->
  <view class="order-status-filter">
    <scroll-view scroll-x="true" class="status-scroll">
      <view class="status-item {{activeStatus === 0 ? 'active' : ''}}" bindtap="selectStatus" data-status="0">
        <text>全部</text>
      </view>
      <view class="status-item {{activeStatus === 1 ? 'active' : ''}}" bindtap="selectStatus" data-status="1">
        <text>待支付</text>
      </view>
      <view class="status-item {{activeStatus === 2 ? 'active' : ''}}" bindtap="selectStatus" data-status="2">
        <text>待发货</text>
      </view>
      <view class="status-item {{activeStatus === 3 ? 'active' : ''}}" bindtap="selectStatus" data-status="3">
        <text>已完成</text>
      </view>
    </scroll-view>
  </view>
  
  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:for="{{orderList}}" wx:key="id">
      <view class="order-item" bindtap="goOrderDetail" data-id="{{item.id}}">
        <view class="order-header">
          <text class="order-id">订单号: {{item.orderNo}}</text>
          <text class="order-status">{{item.status === 1 ? '待支付' : item.status === 2 ? '待发货' : '已完成'}}</text>
        </view>
        <view class="order-content">
          <image src="{{item.fuzhuangImage}}" mode="aspectFill" class="order-image"></image>
          <view class="order-info">
            <text class="order-title">{{item.fuzhuangmingcheng}}</text>
            <text class="order-type">{{item.zujietype === '1' ? '日租' : '月租'}}</text>
            <text class="order-price">¥{{item.totalPrice}}</text>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-time">{{item.addtime}}</text>
          <view class="order-actions">
            <button wx:if="{{item.status === 1}}" class="action-button pay-button" bindtap="goPay">去支付</button>
            <button wx:else class="action-button view-button" bindtap="goOrderDetail" data-id="{{item.id}}">查看详情</button>
          </view>
        </view>
      </view>
    </block>
    <view class="no-data" wx:if="{{orderList.length === 0}}">
      <text>暂无订单</text>
    </view>
  </view>
</view>
