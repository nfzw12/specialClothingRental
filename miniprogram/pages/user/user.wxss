.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息区域 */
.user-info {
  display: flex;
  align-items: center;
  background-color: #1677FF;
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
  display: block;
}

.user-phone {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

.user-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 通用section样式 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 28rpx;
  color: #1677FF;
  text-decoration: none;
}

/* 订单类型 */
.order-types {
  display: flex;
  padding: 20rpx;
  justify-content: space-around;
}

.order-type-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}

.order-type-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.order-type-text {
  font-size: 26rpx;
  color: #333;
}

/* 服务列表 */
.service-list {
  padding: 10rpx 0;
}

.service-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.service-item:last-child {
  border-bottom: none;
}

.service-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.service-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.service-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 退出登录按钮 */
.logout-button {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  margin-top: 40rpx;
}

.logout-button text {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
}

/* 购物车入口 */
.cart-entry {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-entry:last-child {
  border-bottom: none;
}

.cart-entry-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.cart-entry-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.cart-entry-arrow {
  font-size: 36rpx;
  color: #999;
}
