.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
  color: #999;
}

.search-placeholder {
  font-size: 32rpx;
  color: #999;
}

/* 分类导航 */
.category-nav {
  margin-bottom: 20rpx;
  background-color: #fff;
  padding: 10rpx 0;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.category-item {
  display: inline-block;
  padding: 20rpx 30rpx;
  margin-right: 30rpx;
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
  position: relative;
  border-bottom: 3rpx solid transparent;
}

.category-item.active {
  color: #1677FF;
  font-weight: bold;
  border-bottom: 3rpx solid #1677FF;
  font-size: 34rpx;
}

.category-item::after {
  content: '';
  position: absolute;
  bottom: -3rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 3rpx;
  background-color: #1677FF;
  transition: width 0.3s ease;
}

.category-item.active::after {
  width: 80%;
}

/* 服装列表 */
.fuzhuang-list {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 20rpx;
}

.fuzhuang-card {
  flex: 0 0 calc(50% - 10rpx);
  max-width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin: 0;
}

.fuzhuang-card-img {
  width: 100%;
  height: 380rpx;
  object-fit: cover;
}

.fuzhuang-card-info-wrapper {
  padding: 20rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fuzhuang-card-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.fuzhuang-card-tag {
  align-self: flex-start;
  font-size: 22rpx;
  color: #ff4d4f;
  background: #fff0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.fuzhuang-card-price {
  font-size: 32rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-top: 8rpx;
}

/* 空状态 */
.no-data {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}