.container {
  padding: 20rpx;
  background-color: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
  color: #999999;
}

.search-placeholder {
  font-size: 32rpx;
  color: #999999;
}

/* 轮播图 */
.banner {
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.banner swiper {
  width: 100%;
  height: 300rpx;
}

.banner swiper-item image {
  width: 100%;
  height: 100%;
}

/* 分类导航 */
.category {
  margin-bottom: 30rpx;
}

.category-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.category-item {
  width: 22%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
  background-color: #FFFFFF;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.category-item image {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.category-item text {
  font-size: 28rpx;
  color: #333333;
  text-align: center;
}

/* 热门服装 */
.hot-fuzhuang {
  margin-bottom: 30rpx;
}

/* 最新订单 */
.latest-order {
  margin-bottom: 30rpx;
}

/* 通用section样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.more {
  font-size: 28rpx;
  color: #666666;
  text-decoration: none;
}

/* 服装列表 */
.fuzhuang-list {
  display: flex;
  overflow-x: auto;
  padding-bottom: 10rpx;
  scrollbar-width: none;
  -ms-overflow-style: none;
}

.fuzhuang-list::-webkit-scrollbar {
  display: none;
}

.fuzhuang-card {
  width: 280rpx;
  margin-right: 20rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.fuzhuang-card-image {
  width: 100%;
  height: 280rpx;
  object-fit: cover;
}

.fuzhuang-card-content {
  padding: 16rpx;
}

.fuzhuang-card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.fuzhuang-card-price {
  color: #F5222D;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.fuzhuang-card-info {
  font-size: 26rpx;
  color: #666666;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 订单列表 */
.order-list {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.order-item {
  padding: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.order-item:last-child {
  border-bottom: none;
}

.order-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.order-title {
  font-size: 32rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 70%;
}

.order-status {
  font-size: 28rpx;
  color: #1677FF;
  font-weight: bold;
}

.order-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.price {
  color: #F5222D;
  font-size: 36rpx;
  font-weight: bold;
}

.order-type {
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999999;
}

/* 空状态 */
.no-data {
  padding: 40rpx;
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}