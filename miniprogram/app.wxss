/* 基础样式重置 */
page {
  background-color: #F5F5F5;
  font-size: 14px;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

view, text, image, button, input, swiper, swiper-item {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* 通用布局样式 */
.container {
  padding: 20rpx;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 按钮样式 */
.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
  background-color: #1677FF;
  color: #FFFFFF;
}

.btn:active {
  opacity: 0.8;
}

.btn-disabled {
  background-color: #CCCCCC;
  color: #FFFFFF;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 20rpx 0;
  background-color: #FFFFFF;
}

.input:focus {
  border-color: #1677FF;
  outline: none;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin: 20rpx 0;
}

.subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin: 16rpx 0;
}

/* 文本样式 */
.text-primary {
  color: #333333;
}

.text-secondary {
  color: #666666;
}

.text-tertiary {
  color: #999999;
}

.text-small {
  font-size: 28rpx;
}

.text-center {
  text-align: center;
}

/* 间距样式 */
.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

/* 列表样式 */
.list-item {
  background-color: #FFFFFF;
  padding: 20rpx;
  border-bottom: 2rpx solid #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 加载样式 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #666666;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  color: #999999;
}

/* 价格样式 */
.price {
  color: #F5222D;
  font-size: 36rpx;
  font-weight: bold;
}

/* 服装卡片样式 */
.fuzhuang-card {
  background-color: #FFFFFF;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.fuzhuang-card-image {
  width: 100%;
  height: 300rpx;
  object-fit: cover;
}

.fuzhuang-card-content {
  padding: 20rpx;
}

.fuzhuang-card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.fuzhuang-card-price {
  color: #F5222D;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.fuzhuang-card-info {
  font-size: 28rpx;
  color: #666666;
}