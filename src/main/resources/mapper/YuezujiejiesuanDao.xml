<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.YuezujiejiesuanDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.YuezujiejiesuanEntity" id="yuezujiejiesuanMap">
        <result property="dingdanbianhao" column="dingdanbianhao"/>
        <result property="fuzhuangmingcheng" column="fuzhuangmingcheng"/>
        <result property="fuzhuangtupian" column="fuzhuangtupian"/>
        <result property="fuzhuangfenlei" column="fuzhuangfenlei"/>
        <result property="fuzhuangchima" column="fuzhuangchima"/>
        <result property="fuzhuangyanse" column="fuzhuangyanse"/>
        <result property="fuzhuangcailiao" column="fuzhuangcailiao"/>
        <result property="yuezujin" column="yuezujin"/>
        <result property="yuezujieshizhang" column="yuezujieshizhang"/>
        <result property="dingjin" column="dingjin"/>
        <result property="shengyufeiyong" column="shengyufeiyong"/>
        <result property="zujieriqi" column="zujieriqi"/>
        <result property="zujiebeizhu" column="zujiebeizhu"/>
        <result property="yonghuxingming" column="yonghuxingming"/>
        <result property="yonghuzhanghao" column="yonghuzhanghao"/>
        <result property="shouji" column="shouji"/>
        <result property="shouzuriqi" column="shouzuriqi"/>
        <result property="sfsh" column="sfsh"/>
        <result property="shhf" column="shhf"/>
        <result property="ispay" column="ispay"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.YuezujiejiesuanVO" >
		SELECT * FROM yuezujiejiesuan  yuezujiejiesuan         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.YuezujiejiesuanVO" >
		SELECT  yuezujiejiesuan.* FROM yuezujiejiesuan  yuezujiejiesuan 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.YuezujiejiesuanView" >

		SELECT  yuezujiejiesuan.* FROM yuezujiejiesuan  yuezujiejiesuan 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.YuezujiejiesuanView" >
		SELECT * FROM yuezujiejiesuan  yuezujiejiesuan <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	

    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM yuezujiejiesuan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
        limit 10
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM yuezujiejiesuan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM yuezujiejiesuan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM yuezujiejiesuan
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM yuezujiejiesuan
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
        limit 10
    </select>



</mapper>
